<?xml version="1.0" encoding="UTF-8"?>
<!--
  TKAG-35 — Static sitemap for T.kays Agrocosmetics
  NOTE: Dynamic routes such as /shop/:slug require server-side or build-time
  generation (e.g. via a sitemap generation script that queries the product
  catalogue API). Those routes are intentionally omitted here and should be
  appended during the CI/CD build process once the product API is available.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.sitemaps.org/schemas/sitemap/0.9
          http://www.sitemaps.org/schemas/sitemap/0.9/sitemap.xsd">

  <url>
    <loc>https://www.tkaysagrocosmetics.com/</loc>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>https://www.tkaysagrocosmetics.com/about</loc>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://www.tkaysagrocosmetics.com/catalog</loc>
    <changefreq>weekly</changefreq>
    <priority>0.9</priority>
  </url>

  <url>
    <loc>https://www.tkaysagrocosmetics.com/skincare</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://www.tkaysagrocosmetics.com/hair-body</loc>
    <changefreq>weekly</changefreq>
    <priority>0.8</priority>
  </url>

  <url>
    <loc>https://www.tkaysagrocosmetics.com/accessories</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>

  <url>
    <loc>https://www.tkaysagrocosmetics.com/blog</loc>
    <changefreq>weekly</changefreq>
    <priority>0.7</priority>
  </url>

  <url>
    <loc>https://www.tkaysagrocosmetics.com/checkout</loc>
    <changefreq>never</changefreq>
    <priority>0.3</priority>
  </url>

  <!--
    Dynamic product pages (/shop/:slug) are NOT listed here.
    They must be generated at build time by querying the product catalogue API
    and appending <url> entries for each product slug.
    See docs/DEPLOYMENT.md for the recommended approach.
  -->

</urlset>